# ── News Source API Keys (optional — Google News RSS works with no keys) ─────
NEWS_API_KEY=
SERP_API_KEY=
ANTHROPIC_API_KEY=

# ── Supabase (required for dashboard and persistent dedup) ────────────────────
# Create a project at https://app.supabase.com — then run the migration in
# supabase/migrations/001_init.sql before first sync.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=  # for sync job / scraper (bypasses RLS)
SUPABASE_KEY=               # anon key for dashboard (read-only via RLS)

# ── Email (Gmail example — use an App Password, not your real password) ──────
EMAIL_SENDER=you@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_RECIPIENTS=you@gmail.com,colleague@company.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── Schedule ──────────────────────────────────────────────────────────────────
# every_4_hours (default) | hourly | daily | weekly
RUN_SCHEDULE=every_4_hours
RUN_TIME=07:00

# ── Storage (local fallback if Supabase not configured) ──────────────────────
SEEN_RESULTS_FILE=data/seen_results.json
RESULTS_OUTPUT_FILE=data/results.csv

# ── AI Relevance Filter ───────────────────────────────────────────────────────
USE_AI_FILTER=false
AI_RELEVANCE_THRESHOLD=0.7
