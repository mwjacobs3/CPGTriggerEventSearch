# ── API Keys (optional — Google News RSS works with no keys) ──────────────────
NEWS_API_KEY=
SERP_API_KEY=
ANTHROPIC_API_KEY=

# ── Email (Gmail example — use an App Password, not your real password) ───────
EMAIL_SENDER=you@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_RECIPIENTS=you@gmail.com,colleague@company.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── Schedule ──────────────────────────────────────────────────────────────────
RUN_SCHEDULE=daily
RUN_TIME=07:00

# ── Storage ───────────────────────────────────────────────────────────────────
SEEN_RESULTS_FILE=data/seen_results.json
RESULTS_OUTPUT_FILE=data/results.csv

# ── AI Relevance Filter ───────────────────────────────────────────────────────
USE_AI_FILTER=false
AI_RELEVANCE_THRESHOLD=0.7
