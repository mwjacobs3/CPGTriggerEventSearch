# Streamlit Cloud secrets template
# ─────────────────────────────────────────────────────────────────────────────
# On share.streamlit.io: App → Settings → Secrets, paste the values below
# (substitute your own Supabase URL + anon key).
#
# For local runs: copy to .streamlit/secrets.toml (gitignored) or export the
# same names as environment variables.

SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your-anon-key"          # anon key, NOT the service_role key
